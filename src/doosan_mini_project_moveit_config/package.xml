<?xml version="1.0"?>

<?xml-model href="http://download.ros.org/schema/package_format3.xsd"
           schematypens="http://www.w3.org/2001/XMLSchema"?>

<package format="3">

<name>doosan_mini_project_moveit_config</name> <version>0.3.0</version>

  <description>
    An automatically generated package with all the configuration and launch
    files for using the e0509 with the MoveIt Motion Planning Framework
  </description>

<maintainer email="kdydk93052753@gmail.com">kdy</maintainer> <author email="kdydk93052753@gmail.com">kdy</author>

<license>BSD-3-Clause</license>

<url type="website">http://moveit.ros.org/</url> <url type="bugtracker">https://github.com/moveit/moveit2/issues</url> <url type="repository">https://github.com/moveit/moveit2</url>

  <!-- ========================= -->

  <!-- Build system -->

  <!-- ========================= -->

<buildtool_depend>ament_cmake</buildtool_depend>

  <!-- ========================= -->

  <!-- ROS interface generation -->

  <!-- ========================= -->

  <!--
    현재 이 패키지에서는 자체 메시지를 생성하지 않고,
    banana_command 패키지의 Detection 메시지를 사용한다.
  -->

  <!-- <build_depend>rosidl_default_generators</build_depend> -->

  <!-- <exec_depend>rosidl_default_runtime</exec_depend> -->

  <!-- <member_of_group>rosidl_interface_packages</member_of_group> -->

  <!-- ========================= -->

  <!-- C++ node dependencies -->

  <!-- ========================= -->

<depend>rclcpp</depend>
<depend>ament_index_cpp</depend>

<depend>std_msgs</depend> <depend>geometry_msgs</depend> <depend>shape_msgs</depend> <depend>moveit_msgs</depend>

<depend>banana_command</depend>

<depend>moveit_task_constructor_core</depend> <depend>moveit_ros_planning_interface</depend> <depend>moveit_task_constructor_msgs</depend>

<depend>builtin_interfaces</depend>
<depend>nlohmann_json</depend>
<depend>trajectory_msgs</depend>

  <!-- ========================= -->

  <!-- MoveIt runtime -->

  <!-- ========================= -->

<exec_depend>moveit_ros_move_group</exec_depend>
<exec_depend>moveit_kinematics</exec_depend>
<exec_depend>moveit_planners</exec_depend>
<exec_depend>moveit_simple_controller_manager</exec_depend>

<exec_depend>moveit_configs_utils</exec_depend>
<exec_depend>moveit_ros_visualization</exec_depend>
<exec_depend>moveit_ros_warehouse</exec_depend>
<exec_depend>moveit_setup_assistant</exec_depend>

  <!-- ========================= -->

  <!-- Robot and controller -->

  <!-- ========================= -->

<exec_depend>controller_manager</exec_depend>
<exec_depend>doosan_mini_project_cpp</exec_depend>

<exec_depend>joint_state_publisher</exec_depend>
<exec_depend>joint_state_publisher_gui</exec_depend>
<exec_depend>robot_state_publisher</exec_depend>

  <!-- ========================= -->

  <!-- TF / robot description -->

  <!-- ========================= -->

<exec_depend>tf2_ros</exec_depend>
<exec_depend>xacro</exec_depend>

  <!-- ========================= -->

  <!-- RViz -->

  <!-- ========================= -->

<exec_depend>rviz2</exec_depend>
<exec_depend>rviz_common</exec_depend>
<exec_depend>rviz_default_plugins</exec_depend>

  <!-- ========================= -->

  <!-- Warehouse -->

  <!-- ========================= -->

<exec_depend>warehouse_ros_mongo</exec_depend>

  <!-- Gazebo simulation dependencies -->

  <!--
  <exec_depend>joint_trajectory_controller</exec_depend>
  <exec_depend>gazebo_ros_control</exec_depend>
  -->

  <export>
    <build_type>ament_cmake</build_type>
  </export>

</package>
